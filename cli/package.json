{
  "name": "coding-friend-cli",
  "version": "1.33.1",
  "description": "CLI for coding-friend — host learning docs, setup MCP server, initialize projects",
  "type": "module",
  "bin": {
    "cf": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/postinstall.ts --format esm --dts --clean",
    "postinstall": "node -e \"import('./dist/postinstall.js').catch(()=>{})\"",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/index.ts",
    "watch": "tsup src/index.ts src/postinstall.ts --format esm --dts --watch",
    "test": "vitest run && vitest run --config vitest.hooks.config.ts",
    "test:watch": "vitest",
    "test:hooks": "vitest run --config vitest.hooks.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "files": [
    "dist",
    "lib"
  ],
  "keywords": [
    "coding-friend",
    "cli",
    "learning",
    "mcp",
    "claude"
  ],
  "author": {
    "name": "Anh-Thi Dinh",
    "email": "me@dinhanhthi.com",
    "url": "https://dinhanhthi.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dinhanhthi/coding-friend.git",
    "directory": "cli"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.0.0",
    "commander": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
